<script>
const execUrl   = '/plugins/unflared/include/exec.php';
const csrfToken = '<?=htmlspecialchars($csrf)?>';

function post(data) {
  data.csrf_token = csrfToken;
  return fetch(execUrl, {
    method: 'POST',
    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
    body: new URLSearchParams(data)
  }).then(r => r.json());
}

function setMsg(txt, color) {
  const el = document.getElementById('unflared-msg');
  el.style.color = color || '#888';
  el.textContent = txt;
}

function saveToken() {
  const token     = document.getElementById('tokenInput').value.trim();
  const autostart = document.getElementById('autostartInput').checked ? 'yes' : 'no';
  post({ action: 'save', token, autostart }).then(r => {
    setMsg(r.message, r.status === 'ok' ? '#4caf50' : '#f44336');
  });
}

function svcAction(action) {
  setMsg('...');
  post({ action }).then(r => {
    setMsg(r.message, r.status === 'ok' ? '#4caf50' : '#f44336');
    refreshStatus();
  });
}

function refreshStatus() {
  const badge = document.getElementById('statusBadge');
  badge.textContent = 'Checking...';
  badge.className   = 'status-badge badge-checking';
  document.getElementById('verInstalled').textContent = '—';
  document.getElementById('verLatest').textContent    = '—';
  post({ action: 'status' }).then(r => {
    badge.textContent = r.running ? 'Running' : 'Stopped';
    badge.className   = 'status-badge ' + (r.running ? 'badge-running' : 'badge-stopped');
    document.getElementById('verInstalled').textContent = r.installed || '—';
    document.getElementById('verLatest').textContent    = r.latest    || '—';
    document.getElementById('updateBadge').style.display = r.update ? 'inline-block' : 'none';
  });
}

refreshStatus();
setInterval(refreshStatus, 30000);
</script>
